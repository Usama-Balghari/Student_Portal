@model Student_Portal2.Models.Department



<form asp-action="Create">
    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

    <div class="mb-4">
        <label asp-for="DepartmentName" class="sp-form-label">Department Name</label>
        <input asp-for="DepartmentName"
               class="sp-form-control"
               placeholder="e.g. Computer Science" />
        <span asp-validation-for="DepartmentName" class="text-danger small mt-1 d-block"></span>
    </div>

    <div class="d-flex justify-content-end">
        <input type="submit" value="Create Department" class="btn btn-sp-submit" />
    </div>
</form>
