@model Student_Portal2.Models.Department



<form asp-action="Edit" id="editDeptForm">
    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
    <input type="hidden" asp-for="Id" />

    <div class="mb-4">
        <label asp-for="DepartmentName" class="sp-form-label">Department Name</label>
        <input asp-for="DepartmentName"
               class="sp-form-control"
               placeholder="e.g. Computer Science" />
        <span asp-validation-for="DepartmentName" class="text-danger small mt-1 d-block"></span>
    </div>

    <div class="d-flex justify-content-between align-items-center">
        <a asp-action="Index" class="btn-sp-back">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z" />
            </svg>
            Back to List
        </a>
        <input type="submit" value="Save Changes" class="btn btn-sp-submit" />
    </div>
</form>
