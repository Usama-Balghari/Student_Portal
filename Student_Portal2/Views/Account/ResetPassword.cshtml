@model Student_Portal2.Models.RegisterViewModel;

<style>
    :root {
        --ink: #0d1321;
        --indigo-deep: #1b2b5e;
        --indigo: #2d3f8a;
        --indigo-soft: #3d52a8;
        --amber: #f5a623;
        --surface-2: #f4f6ff;
        --text-main: #1a1f3c;
        --text-muted: #7a85aa;
        --border: #dde2f3;
        --ff-display: 'Fraunces', Georgia, serif;
        --ff-body: 'Outfit', sans-serif;
    }

    body {
        background: var(--surface-2) !important;
    }

    .rg-page {
        min-height: calc(100vh - 120px);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 40px 16px;
        font-family: var(--ff-body);
    }

    .rg-card {
        width: 100%;
        max-width: 420px;
        border: none !important;
        border-radius: 22px !important;
        overflow: hidden;
        box-shadow: 0 24px 64px rgba(13,19,33,0.15), 0 4px 16px rgba(13,19,33,0.07) !important;
    }

    .rg-hero {
        background: var(--indigo-deep);
        padding: 32px 32px 28px;
        position: relative;
        overflow: hidden;
        text-align: center;
    }

        .rg-hero::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image: linear-gradient(rgba(255,255,255,0.035) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.035) 1px, transparent 1px);
            background-size: 28px 28px;
            pointer-events: none;
        }

    .rg-hero-icon {
        width: 58px;
        height: 58px;
        border-radius: 16px;
        background: rgba(245,166,35,0.15);
        border: 1px solid rgba(245,166,35,0.35);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 14px;
        position: relative;
        z-index: 1;
    }

    .rg-hero-eyebrow {
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 2.5px;
        text-transform: uppercase;
        color: var(--amber);
        margin-bottom: 4px;
        position: relative;
        z-index: 1;
    }

    .rg-hero-title {
        font-family: var(--ff-display);
        font-size: 26px;
        color: #fff;
        margin-bottom: 5px;
        line-height: 1.15;
        position: relative;
        z-index: 1;
    }

    .rg-hero-sub {
        font-size: 13px;
        color: rgba(255,255,255,0.45);
        font-weight: 300;
        margin: 0;
        position: relative;
        z-index: 1;
    }

    .rg-body {
        padding: 28px 32px 28px;
        background: #fff;
    }

    .rg-section-label {
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--text-muted);
        display: flex;
        align-items: center;
        gap: 10px;
        margin: 0 0 14px;
    }

        .rg-section-label::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--border);
        }

    .rg-label {
        font-size: 10.5px;
        font-weight: 600;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: 6px;
        display: block;
    }

    .rg-input {
        font-family: var(--ff-body) !important;
        font-size: 14px !important;
        background: var(--surface-2) !important;
        border: 1.5px solid var(--border) !important;
        border-radius: 11px !important;
        padding: 11px 14px !important;
        color: var(--text-main) !important;
        transition: border-color 0.2s, box-shadow 0.2s !important;
        width: 100%;
    }

        .rg-input:focus {
            border-color: var(--indigo-soft) !important;
            box-shadow: 0 0 0 4px rgba(61,82,168,0.10) !important;
            background: #fff !important;
            outline: none;
        }

        .rg-input::placeholder {
            color: #b0bace !important;
        }

    .rg-hint {
        font-size: 11.5px;
        color: #b0bace;
        margin-top: 6px;
        display: block;
        font-family: var(--ff-body);
    }

    .btn-rg-submit {
        background: var(--amber) !important;
        border: none !important;
        color: var(--ink) !important;
        font-family: var(--ff-body) !important;
        font-size: 14px !important;
        font-weight: 600 !important;
        border-radius: 999px !important;
        padding: 12px 24px !important;
        transition: background 0.2s !important;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 7px;
    }

        .btn-rg-submit:hover {
            background: #e09520 !important;
            color: var(--ink) !important;
        }
</style>

<div class="rg-page">
    <div class="card rg-card">

        @* {{-- Hero - title switches based on TempData --}} *@
        <div class="rg-hero">
            <div class="rg-hero-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" fill="white" viewBox="0 0 16 16">
                    <path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z" />
                </svg>
            </div>
            <p class="rg-hero-eyebrow">Student Portal</p>
            @if (TempData["T2"] != null)
            {
                <h1 class="rg-hero-title">Set Password</h1>
            }
            else
            {
                <h1 class="rg-hero-title">Reset Password</h1>
            }
            <p class="rg-hero-sub">Enter your new password below</p>
        </div>

        <div class="rg-body">
            <form method="post" asp-action="ResetPassword" class="needs-validation" novalidate>

                <input type="hidden" asp-for="Email" />
                <input type="hidden" asp-for="Token" />

                <p class="rg-section-label">New Password</p>

                <div class="mb-3">
                    <label class="rg-label">Password</label>
                    <input asp-for="NewPassword" type="password"
                           class="rg-input" placeholder="••••••••" required />
                    <span asp-validation-for="NewPassword" class="text-danger small mt-1 d-block"></span>
                    <small class="rg-hint">At least 8 characters with letters and numbers.</small>
                </div>

                <div class="mb-4">
                    <label class="rg-label">Confirm Password</label>
                    <input asp-for="ConfirmPassword" type="password"
                           class="rg-input" placeholder="••••••••" required />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small mt-1 d-block"></span>
                </div>

                <div asp-validation-summary="ModelOnly" class="text-danger small text-center mb-3"></div>

                <button type="submit" class="btn btn-rg-submit w-100">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M13.854 3.646a.5.5 0 0 1 0 .708l-7 7a.5.5 0 0 1-.708 0l-3.5-3.5a.5.5 0 1 1 .708-.708L6.5 10.293l6.646-6.647a.5.5 0 0 1 .708 0z" />
                    </svg>
                    Update Password
                </button>

            </form>
        </div>
    </div>
</div>
