@model Student_Portal2.Models.RegisterViewModel;


<div class="d-flex justify-content-center">
    <div class="card bg-secondary shadow border-0 mx-auto" style="width: 320px; height:100vh">

        <!-- Card Header -->
        <div class="card-header bg-gradient pb-2">
                @if (TempData["T"] != null) {
            <div class="text-center text-white mb-3 login-header h4">
                    Reset Password
            </div>
                }
            @if (TempData["T2"] != null)
            {
                <div class="text-center text-white mb-3 login-header h4">
                    Set Password
                </div>
            }
        </div>

        <!-- Card Body -->
        <div class="card-body px-lg-4 py-lg-3 bg-light">
            <div class="text-center text-black mb-3">
                <p>Enter your new password</p>
            </div>

            <form method="post"
                  asp-action="ResetPassword"
                  class="needs-validation"
                  novalidate>

                <!-- Hidden fields -->
                <input type="hidden" asp-for="Email" />
                <input type="hidden" asp-for="Token" />

                <!-- New Password -->
                <div class="form-group mb-3 text-center">
                    <input asp-for="NewPassword"
                           type="password"
                           class="form-control mx-auto"
                           placeholder="New Password"
                           style="max-width: 320px;"
                           required />
                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                </div>

                <!-- Confirm Password -->
                <div class="form-group mb-3 text-center">
                    <input asp-for="ConfirmPassword"
                           type="password"
                           class="form-control mx-auto"
                           placeholder="Confirm Password"
                           style="max-width: 320px;"
                           required />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <div asp-validation-summary="ModelOnly"
                     class="text-danger text-center mb-2"></div>

                <!-- Submit Button -->
                <div class="text-center">
                    <button type="submit"
                            class="btn btn-primary w-100"
                            style="max-width: 320px;">
                        Update Password
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>
