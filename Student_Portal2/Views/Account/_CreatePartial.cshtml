@model Student_Portal2.Models.UserEditViewModel

<style>
    .sp-form-label {
        font-size: 10.5px;
        font-weight: 600;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #7a85aa;
        margin-bottom: 7px;
        display: block;
        font-family: 'Outfit', sans-serif;
    }

    .sp-form-control {
        font-family: 'Outfit', sans-serif !important;
        font-size: 14px !important;
        background: #f4f6ff !important;
        border: 1.5px solid #dde2f3 !important;
        border-radius: 11px !important;
        padding: 10px 14px !important;
        color: #1a1f3c !important;
        transition: border-color 0.2s, box-shadow 0.2s !important;
        width: 100%;
    }

        .sp-form-control:focus {
            border-color: #3d52a8 !important;
            box-shadow: 0 0 0 4px rgba(61,82,168,0.10) !important;
            background: #fff !important;
            outline: none;
        }

        .sp-form-control::placeholder {
            color: #b0bace !important;
        }

    /* Section divider */
    .sp-section-label {
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: #7a85aa;
        margin: 20px 0 14px;
        display: flex;
        align-items: center;
        gap: 10px;
        font-family: 'Outfit', sans-serif;
    }

        .sp-section-label::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #dde2f3;
        }

    /* Admin toggle card */
    .sp-admin-toggle {
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: #f4f6ff;
        border: 1.5px solid #dde2f3;
        border-radius: 14px;
        padding: 14px 18px;
        margin-bottom: 22px;
        cursor: pointer;
        transition: border-color 0.2s, background 0.2s;
    }

        .sp-admin-toggle:has(input:checked) {
            border-color: #f5a623;
            background: #fffbf0;
        }

    .sp-admin-toggle-left {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .sp-admin-toggle-icon {
        width: 38px;
        height: 38px;
        border-radius: 11px;
        background: rgba(245,166,35,0.12);
        border: 1px solid rgba(245,166,35,0.28);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .sp-admin-toggle-title {
        font-size: 13.5px;
        font-weight: 600;
        color: #1a1f3c;
        margin: 0 0 2px;
        font-family: 'Outfit', sans-serif;
    }

    .sp-admin-toggle-sub {
        font-size: 11.5px;
        color: #7a85aa;
        margin: 0;
        font-family: 'Outfit', sans-serif;
    }

    /* Custom toggle switch */
    .sp-switch {
        position: relative;
        display: inline-block;
        width: 42px;
        height: 24px;
        flex-shrink: 0;
    }

        .sp-switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

    .sp-slider {
        position: absolute;
        cursor: pointer;
        inset: 0;
        background: #dde2f3;
        border-radius: 999px;
        transition: background 0.25s;
    }

        .sp-slider::before {
            content: '';
            position: absolute;
            width: 18px;
            height: 18px;
            left: 3px;
            bottom: 3px;
            background: #fff;
            border-radius: 50%;
            transition: transform 0.25s;
            box-shadow: 0 1px 4px rgba(0,0,0,0.18);
        }

    .sp-switch input:checked + .sp-slider {
        background: #f5a623;
    }

        .sp-switch input:checked + .sp-slider::before {
            transform: translateX(18px);
        }

    /* Submit button */
    .btn-sp-create {
        background: linear-gradient(135deg, #f5a623, #fcd97e) !important;
        border: none !important;
        color: #0d1321 !important;
        font-family: 'Outfit', sans-serif !important;
        font-size: 14px !important;
        font-weight: 600 !important;
        border-radius: 999px !important;
        padding: 11px 28px !important;
        box-shadow: 0 5px 18px rgba(245,166,35,0.35) !important;
        transition: all 0.22s ease !important;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 7px;
    }

        .btn-sp-create:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 26px rgba(245,166,35,0.48) !important;
            filter: brightness(1.05);
            color: #0d1321 !important;
        }

        .btn-sp-create:active {
            transform: translateY(0) !important;
        }
</style>

<form asp-action="Create" method="post" id="createUser">

    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

    @* Personal Info *@
    <p class="sp-section-label">Personal Information</p>

    <div class="row g-3 mb-1">
        <div class="col-6">
            <label class="sp-form-label">First Name</label>
            <input asp-for="FirstName" class="sp-form-control" placeholder="First name" />
            <span asp-validation-for="FirstName" class="text-danger small mt-1 d-block"></span>
        </div>
        <div class="col-6">
            <label class="sp-form-label">Last Name</label>
            <input asp-for="LastName" class="sp-form-control" placeholder="Last name" />
            <span asp-validation-for="LastName" class="text-danger small mt-1 d-block"></span>
        </div>
        <div class="col-12">
            <label class="sp-form-label">Username</label>
            <input asp-for="UserName" class="sp-form-control" placeholder="Username" />
            <span asp-validation-for="UserName" class="text-danger small mt-1 d-block"></span>
        </div>
    </div>

    @* Account Info *@
    <p class="sp-section-label">Account</p>

    <div class="row g-3 mb-1">
        <div class="col-12">
            <label class="sp-form-label">Email Address</label>
            <input asp-for="Email" class="sp-form-control" placeholder="you@example.com" type="email" />
            <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
        </div>
        <div class="col-12">
            <label class="sp-form-label">Password</label>
            <input asp-for="NewPassword" class="sp-form-control" placeholder="••••••••" type="password" />
            <span asp-validation-for="NewPassword" class="text-danger small mt-1 d-block"></span>
        </div>
    </div>

    @* Admin toggle *@
    <p class="sp-section-label">Permissions</p>

    <label class="sp-admin-toggle">
        <div class="sp-admin-toggle-left">
            <div class="sp-admin-toggle-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" fill="#a06c00" viewBox="0 0 16 16">
                    <path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z" />
                </svg>
            </div>
            <div>
                <div class="sp-admin-toggle-title">Grant Admin Access</div>
                <div class="sp-admin-toggle-sub">User will have full administrative privileges</div>
            </div>
        </div>
        <label class="sp-switch" onclick="event.stopPropagation()">
            <input asp-for="IsAdmin" type="checkbox" />
            <span class="sp-slider"></span>
        </label>
    </label>

    @* Submit *@
    <div class="d-flex justify-content-end">
        <button type="submit" class="btn btn-sp-create">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z" />
            </svg>
            Create User
        </button>
    </div>

</form>
