@model Student_Portal2.Models.Course


<form asp-action="Create">
    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

    <div class="mb-4">
        <label asp-for="CourseName" class="sp-form-label">Course Name</label>
        <input asp-for="CourseName"
               class="sp-form-control"
               placeholder="e.g. Introduction to Programming" />
        <span asp-validation-for="CourseName" class="text-danger small mt-1 d-block"></span>
    </div>

    <div class="d-flex justify-content-end">
        <input type="submit" value="Create Course" class="btn btn-sp-submit" />
    </div>
</form>
